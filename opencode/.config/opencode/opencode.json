{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".windsurf/rules/*.md"
  ],
  "mcp": {
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "file:./.secrets/context7"
      },
      "enabled": true
    },
    "pencil": {
      "command": [
        "/opt/pencil/resources/app.asar.unpacked/out/mcp-server-linux-x64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}
